{
  "title": "Bundibugyo ebolavirus genomes",
  "maintainers": [
    {"name": "GenomicEpi", "url": "https://github.com/genomicepi"}
  ],
  "data_provenance": [
    {
      "name": "Pathoplexus",
      "url": "https://pathoplexus.org"
    }
  ],
  "build_url": "https://github.com/genomicepi/ebola",
  "colorings": [
    {
      "key": "gt",
      "title": "Genotype",
      "type": "categorical"
    },
    {
      "key": "date",
      "title": "Sampling Date",
      "type": "temporal"
    },
    {
      "key": "outbreak_label",
      "title": "Outbreak",
      "type": "categorical",
      "scale": [
        ["2007 Outbreak", "#78c2ad"],
        ["2012 Outbreak", "#6cc3d5"],
        ["2026 Outbreak", "#ff7851"]
      ]
    },
    {
      "key": "author",
      "title": "Author",
      "type":"categorical"
    },
    {
      "key": "country",
      "title": "Country",
      "type": "categorical"
    },
    {
      "key": "country_label",
      "title": "Country label",
      "type": "categorical"
    },
    {
      "key": "division",
      "title": "Division",
      "type": "categorical"
    },
    {
      "key": "dataUseTerms",
      "title": "Data use terms",
      "type": "categorical"
    }
  ],
  "geo_resolutions": [
    "country",
    "division"
  ],
  "display_defaults": {
    "tip_label": "country_label",
    "color_by": "outbreak_label",
    "geo_resolution": "division"
  },
  "filters": [
    "outbreak_label",
    "country",
    "division",
    "author"
  ],
  "metadata_columns": [
    "PPX_accession",
    "INSDC_accession",
    "restrictedUntil",
    "outbreak",
    "outbreak_label",
    "country_label",
    "strain"
  ]
}
